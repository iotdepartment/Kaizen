@model Kaizen.Models.KaizenIdea

<h3>Propuesta Kaizen #@Model.Id</h3>
<p><strong>Empleado:</strong> @Model.NoEmpleado - @Model.Empleado?.Nombre</p>
<p><strong>Supervisor:</strong> @Model.Supervisor</p>
<p><strong>Área:</strong> @Model.Area</p>
<p><strong>Turno:</strong> @Model.Turno</p>
<p><strong>Descripción:</strong> @Model.Descripcion</p>

<hr />
<h4>Estado actual: @Model.Estado</h4>
@if (!string.IsNullOrEmpty(Model.EstadoComentario))
{
    <p><strong>Comentario de estado:</strong> @Model.EstadoComentario</p>
    <p><small>@Model.EstadoFecha?.ToString("g")</small></p>
}

<form asp-action="CambiarEstado" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <select name="nuevoEstado" class="form-select">
        <option>Pendiente</option>
        <option>En revisión</option>
        <option>Aprobada</option>
        <option>Rechazada</option>
    </select>
    <textarea name="comentario" class="form-control mt-2" placeholder="Comentario sobre el cambio de estado"></textarea>
    <button type="submit" class="btn btn-primary mt-2">Actualizar estado</button>
</form>

<hr />
<h5>Comentarios</h5>
<ul class="list-group">
    @foreach (var c in Model.Comentarios)
    {
        <li class="list-group-item">
            <strong>@c.Usuario</strong> (@c.FechaComentario.ToShortDateString()):
            @c.Comentario
        </li>
    }
</ul>