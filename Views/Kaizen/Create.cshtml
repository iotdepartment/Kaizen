@{
    ViewData["Title"] = "Registrar Idea Kaizen";
}

<!-- Fabric.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.2.4/fabric.min.js"></script>

<style>
    .canvas-box {
        border: 1px solid #ccc;
        border-radius: 6px;
        background: white;
    }

    .toolbar button {
        margin-right: 5px;
    }
</style>

<div class="mx-auto mt-4 p-4 px-5 shadow-sm bg-body rounded-pill text-center d-inline-block">
    <h3 class="fw-bold mb-0">Registrar Idea Kaizen</h3>
</div>

<div class="container rounded-4 bg-body p-5 mt-2 shadow-lg">

    @* <h3 class="fw-bold mb-4">Registrar Idea Kaizen</h3> *@

    <!-- No. Empleado + Nombre -->
    <div class="row mb-3">
        <div class="col-md-4 position-relative">
            <label class="fw-bold">No. Empleado</label>
            <input id="NoEmpleado" class="form-control" autocomplete="off" />
            <div id="empleadoList" class="list-group position-absolute w-100" style="z-index: 1000;"></div>
        </div>
        <div class="col-md-8">
            <label class="fw-bold">Nombre</label>
            <input id="NombreEmpleado" class="form-control" disabled />
        </div>
    </div>

    <!-- Supervisor / Área / Turno -->
    <div class="row mb-3">
        <div class="col-md-4">
            <label class="fw-bold">Supervisor</label>
            <input id="Supervisor" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="fw-bold">Área</label>
            <select id="Area" class="form-select">
                <option value="">Seleccione un área</option>
                <option value="Mixing">Mixing</option>
                <option value="Extruder">Extruder</option>
                <option value="Oven">Oven</option>
                <option value="Inspeccion">Inspección</option>
                <option value="Ensamble">Ensamble</option>
                <option value="Safe Launch">Safe Launch</option>
            </select>
        </div>

        <div class="col-md-4">
            <label class="fw-bold">Turno</label>
            <select id="Turno" class="form-select">
                <option value="1">1er Turno</option>
                <option value="2">2do Turno</option>
                <option value="3">3er Turno</option>
            </select>
        </div>
    </div>

    <!-- Área donde aplica -->
    <div class="mb-3">
        <label class="fw-bold">Área donde aplica la idea</label>
        <input id="AreaAplicacion" class="form-control" />
    </div>

    <!-- Descripción -->
    <div class="mb-3">
        <label class="fw-bold">Descripción</label>
        <textarea id="Descripcion" class="form-control" rows="4"></textarea>
    </div>
    <hr />

    <h5 class="fw-bold fs-3 mt-4 mb-1 text-primary">Ilustración de la Idea</h5>
    <p class="text-muted mb-3">
        Ilustra tu idea de mejora utilizando dibujos, figuras o texto. Representa visualmente el problema y la solución propuesta.
    </p>

    <!-- Herramientas globales -->
    <div class="d-inline-flex align-items-center gap-3 mb-4 p-2 bg-light rounded border shadow-sm w-auto">
        <div>
            <label class="fw-bold me-2">Color:</label>
            <input type="color" id="colorPicker" value="#000000" class="form-control form-control-color d-inline-block">
        </div>
    </div>

    <div class="row g-4">

        <!-- Estado Actual -->
        <div class="col-12">
            <div class="p-3 border rounded shadow-sm bg-body-tertiary">

                <label class="fw-bold fs-4 mb-1 d-block text-secondary">1. Estado Actual</label>
                <p class="text-muted mb-3">
                    Describe o dibuja cómo es el proceso actualmente. Señala problemas, retrasos, riesgos o cualquier situación que deba mejorarse.
                </p>

                <!-- Toolbar -->
                <div class="btn-toolbar mb-3" role="toolbar">

                    <!-- Grupo dibujo -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="setMode('actual','draw')" class="btn btn-dark btn-sm"><i class="bi bi-pencil-fill"></i></button>
                        <button onclick="setMode('actual','erase')" class="btn btn-secondary btn-sm"><i class="bi bi-eraser-fill"></i></button>
                        <button onclick="setMode('actual','select')" class="btn btn-info btn-sm"><i class="bi bi-cursor-fill"></i></button>
                    </div>

                    <!-- Grupo figuras -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="addRect('actual')" class="btn btn-primary btn-sm"><i class="bi bi-square"></i></button>
                        <button onclick="addCircle('actual')" class="btn btn-primary btn-sm"><i class="bi bi-circle"></i></button>
                        <button onclick="addTriangle('actual')" class="btn btn-primary btn-sm"><i class="bi bi-triangle"></i></button>
                        <button onclick="addArrow('actual')" class="btn btn-primary btn-sm"><i class="bi bi-arrow-right"></i></button>
                    </div>

                    <!-- Texto -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="addText('actual')" class="btn btn-warning btn-sm"><i class="bi bi-type"></i></button>
                    </div>

                    <!-- Undo/Redo -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="undo('actual')" class="btn btn-outline-dark btn-sm"><i class="bi bi-arrow-counterclockwise"></i></button>
                        <button onclick="redo('actual')" class="btn btn-outline-dark btn-sm"><i class="bi bi-arrow-clockwise"></i></button>
                    </div>

                    <!-- Limpiar -->
                    <div class="btn-group" role="group">
                        <button onclick="clearCanvas('actual')" class="btn btn-danger btn-sm"><i class="bi bi-trash-fill"></i></button>
                    </div>

                </div>

                <!-- Canvas -->
                <div class="canvas-box w-100 border-3 rounded shadow-sm p-2">
                    <canvas id="canvasActual" width="1200" height="350" class="w-100"></canvas>
                </div>

            </div>
        </div>

        <!-- Estado Mejorado -->
        <div class="col-12">
            <div class="p-3 border rounded shadow-sm bg-body-tertiary">

                <label class="fw-bold fs-4 mb-1 d-block text-secondary">2. Estado Mejorado</label>
                <p class="text-muted mb-3">
                    Representa cómo debería funcionar el proceso después de aplicar tu mejora. Muestra el flujo ideal, reducción de pasos o eliminación de desperdicios.
                </p>

                <!-- Toolbar -->
                <div class="btn-toolbar mb-3" role="toolbar">

                    <!-- Grupo dibujo -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="setMode('mejorado','draw')" class="btn btn-dark btn-sm"><i class="bi bi-pencil-fill"></i></button>
                        <button onclick="setMode('mejorado','erase')" class="btn btn-secondary btn-sm"><i class="bi bi-eraser-fill"></i></button>
                        <button onclick="setMode('mejorado','select')" class="btn btn-info btn-sm"><i class="bi bi-cursor-fill"></i></button>
                    </div>

                    <!-- Grupo figuras -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="addRect('mejorado')" class="btn btn-primary btn-sm"><i class="bi bi-square"></i></button>
                        <button onclick="addCircle('mejorado')" class="btn btn-primary btn-sm"><i class="bi bi-circle"></i></button>
                        <button onclick="addTriangle('mejorado')" class="btn btn-primary btn-sm"><i class="bi bi-triangle"></i></button>
                        <button onclick="addArrow('mejorado')" class="btn btn-primary btn-sm"><i class="bi bi-arrow-right"></i></button>
                    </div>

                    <!-- Texto -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="addText('mejorado')" class="btn btn-warning btn-sm"><i class="bi bi-type"></i></button>
                    </div>

                    <!-- Undo/Redo -->
                    <div class="btn-group me-2" role="group">
                        <button onclick="undo('mejorado')" class="btn btn-outline-dark btn-sm"><i class="bi bi-arrow-counterclockwise"></i></button>
                        <button onclick="redo('mejorado')" class="btn btn-outline-dark btn-sm"><i class="bi bi-arrow-clockwise"></i></button>
                    </div>

                    <!-- Limpiar -->
                    <div class="btn-group" role="group">
                        <button onclick="clearCanvas('mejorado')" class="btn btn-danger btn-sm"><i class="bi bi-trash-fill"></i></button>
                    </div>

                </div>

                <!-- Canvas -->
                <div class="canvas-box w-100 border-3 rounded shadow-sm p-2">
                    <canvas id="canvasMejorado" width="1200" height="350" class="w-100"></canvas>
                </div>

            </div>
        </div>

    </div>

    <!-- Botón Guardar -->
    <button id="btnGuardar" class="btn btn-success rounded-pill btn-lg mt-4 w-100 shadow">
        <i class="bi bi-save-fill me-2"></i> Enviar Idea
    </button>
</div>

@section Scripts {

    <script>
        /* ============================
           AUTOCOMPLETADO DE EMPLEADOS
        ============================ */
        const inputEmpleado = document.getElementById("NoEmpleado");
        const listEmpleado = document.getElementById("empleadoList");

        inputEmpleado.addEventListener("input", async function () {
            const query = this.value.trim();
            listEmpleado.innerHTML = "";

            if (query.length < 1) return;

            const response = await fetch(`/Kaizen/SearchEmpleados?query=${query}`);
            const empleados = await response.json();

            empleados.forEach(emp => {
                const item = document.createElement("button");
                item.type = "button";
                item.classList.add("list-group-item", "list-group-item-action");
                item.textContent = `${emp.noEmpleado} - ${emp.nombre}`;

                item.addEventListener("click", () => {
                    inputEmpleado.value = emp.noEmpleado;
                    document.getElementById("NombreEmpleado").value = emp.nombre;
                    listEmpleado.innerHTML = "";
                });

                listEmpleado.appendChild(item);
            });
        });

        // Ocultar lista si se hace clic fuera
        document.addEventListener("click", function (e) {
            if (!inputEmpleado.contains(e.target)) {
                listEmpleado.innerHTML = "";
            }
        });
    </script>
    <script>
        /* ============================
           OBTENER IMAGEN BASE64
        ============================ */
        function getCanvasImage(type) {
            return canvases[type].toDataURL({
                format: 'png',
                quality: 1.0
            });
        }

        /* ============================
           GUARDAR INFORMACIÓN CON SWEETALERT TOAST
        ============================ */
        document.getElementById("btnGuardar").addEventListener("click", async () => {

            const imagenActual = getCanvasImage("actual");
            const imagenMejorado = getCanvasImage("mejorado");

            const data = {
                noEmpleado: parseInt(document.getElementById("NoEmpleado").value),
                supervisor: document.getElementById("Supervisor").value,
                area: document.getElementById("Area").value,
                turno: parseInt(document.getElementById("Turno").value),
                areaAplicacion: document.getElementById("AreaAplicacion").value,
                descripcion: document.getElementById("Descripcion").value,
                imagenActualBase64: imagenActual,
                imagenMejoradaBase64: imagenMejorado
            };

            // Validación mínima
            if (!data.noEmpleado || !data.supervisor || !data.area || !data.areaAplicacion || !data.descripcion) {
                Swal.fire({
                    toast: true,
                    position: "top-end",
                    icon: "error",
                    title: "Completa todos los campos obligatorios",
                    showConfirmButton: false,
                    timer: 2500
                });
                return;
            }

            const response = await fetch("/Kaizen/Create", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            // Si hubo error del backend
            if (!response.ok) {
                const error = await response.json();

                Swal.fire({
                    toast: true,
                    position: "top-end",
                    icon: "error",
                    title: error.message,
                    showConfirmButton: false,
                    timer: 2500
                });

                return;
            }

            // Éxito
            const result = await response.json();

            Swal.fire({
                toast: true,
                position: "top-end",
                icon: "success",
                title: result.message,
                showConfirmButton: false,
                timer: 2500
            });

            // Opcional: limpiar formulario después de guardar
            setTimeout(() => {
                location.reload();
            }, 2600);
        });
    </script>

    <script>

              /* ============================
           ALINEACIÓN MAGNÉTICA
        ============================ */
        function enableSnap(c) {
            const grid = 20;

            c.on("object:moving", function (e) {
                const obj = e.target;
                obj.set({
                    left: Math.round(obj.left / grid) * grid,
                    top: Math.round(obj.top / grid) * grid
                });
            });
        }

        /* ============================
           INICIALIZAR CANVAS
        ============================ */
        var canvasActual = new fabric.Canvas('canvasActual');
        var canvasMejorado = new fabric.Canvas('canvasMejorado');

        const canvases = {
            actual: canvasActual,
            mejorado: canvasMejorado
        };

        /* ============================
           AJUSTAR TAMAÑO DEL CANVAS
        ============================ */
        function resizeCanvas(type) {
            const c = canvases[type];
            const container = c.upperCanvasEl.parentNode;

            c.setWidth(container.clientWidth);
            c.setHeight(350);

            c.renderAll();
        }

        resizeCanvas("actual");
        resizeCanvas("mejorado");

        enableSnap(canvasActual);
        enableSnap(canvasMejorado);

        window.addEventListener("resize", () => {
            resizeCanvas("actual");
            resizeCanvas("mejorado");
        });

        /* ============================
           HISTORIAL (DESHACER/REHACER)
        ============================ */
        const history = {
            actual: [],
            mejorado: []
        };

        const redoStack = {
            actual: [],
            mejorado: []
        };

        function saveState(type) {
            const c = canvases[type];
            redoStack[type] = [];
            history[type].push(JSON.stringify(c.toJSON()));
        }

        // Guardar estado inicial
        saveState("actual");
        saveState("mejorado");

        /* Registrar cambios SOLO cuando el usuario modifica algo */
        Object.keys(canvases).forEach(type => {
            const c = canvases[type];

            c.on("object:added", () => {
                if (c._skipHistory) return;
                saveState(type);
            });

            c.on("object:modified", () => {
                if (c._skipHistory) return;
                saveState(type);
            });

            c.on("object:removed", () => {
                if (c._skipHistory) return;
                saveState(type);
            });
        });

        /* ============================
           UNDO
        ============================ */
        function undo(type) {
            const c = canvases[type];

            if (history[type].length > 1) {
                redoStack[type].push(history[type].pop());
                const prev = history[type][history[type].length - 1];

                c._skipHistory = true;
                c.loadFromJSON(prev, () => {
                    c.renderAll();
                    c._skipHistory = false;
                });
            }
        }

        /* ============================
           REDO
        ============================ */
        function redo(type) {
            const c = canvases[type];

            if (redoStack[type].length > 0) {
                const state = redoStack[type].pop();
                history[type].push(state);

                c._skipHistory = true;
                c.loadFromJSON(state, () => {
                    c.renderAll();
                    c._skipHistory = false;
                });
            }
        }

        /* ============================
           MODOS DE DIBUJO
        ============================ */
        function setMode(type, mode) {
            const c = canvases[type];
            const color = document.getElementById("colorPicker").value;

            c.discardActiveObject();
            c.renderAll();

            if (mode === "draw") {
                c.isDrawingMode = true;
                c.freeDrawingBrush = new fabric.PencilBrush(c);
                c.freeDrawingBrush.color = color;
                c.freeDrawingBrush.width = 3;
                return;
            }

            if (mode === "erase") {
                c.isDrawingMode = true;
                c.freeDrawingBrush = new fabric.PencilBrush(c);
                c.freeDrawingBrush.color = "white";
                c.freeDrawingBrush.width = 20;
                return;
            }

            if (mode === "select") {
                c.isDrawingMode = false;
                return;
            }
        }

        /* ============================
           FIGURAS
        ============================ */
        function addRect(type) {
            const c = canvases[type];
            c.isDrawingMode = false;

            c.add(new fabric.Rect({
                left: 50,
                top: 50,
                width: 120,
                height: 80,
                fill: document.getElementById("colorPicker").value,
                stroke: "black",
                strokeWidth: 2
            }));
        }

        function addCircle(type) {
            const c = canvases[type];
            c.isDrawingMode = false;

            c.add(new fabric.Circle({
                left: 80,
                top: 80,
                radius: 40,
                fill: document.getElementById("colorPicker").value,
                stroke: "black",
                strokeWidth: 2
            }));
        }

        function addTriangle(type) {
            const c = canvases[type];
            c.isDrawingMode = false;

            c.add(new fabric.Triangle({
                left: 10,
                top: 100,
                width: 100,
                height: 100,
                fill: document.getElementById("colorPicker").value,
                stroke: "black",
                strokeWidth: 2
            }));
        }

        function addArrow(type) {
            const c = canvases[type];
            c.isDrawingMode = false;

            const color = document.getElementById("colorPicker").value;

            const line = new fabric.Line([50, 100, 150, 100], {
                stroke: color,
                strokeWidth: 4
            });

            const triangle = new fabric.Triangle({
                left: 160,
                top: 93,
                width: 15,
                height: 15,
                fill: color,
                angle: 90
            });

            const group = new fabric.Group([line, triangle], { selectable: true });
            c.add(group);
        }

        /* ============================
           TEXTO
        ============================ */
        function addText(type) {
            const c = canvases[type];
            c.isDrawingMode = false;

            c.add(new fabric.Textbox("Texto aquí", {
                left: 50,
                top: 50,
                fontSize: 20,
                fill: document.getElementById("colorPicker").value,
                editable: true
            }));
        }

        /* ============================
           LIMPIAR
        ============================ */
        function clearCanvas(type) {
            canvases[type].clear();
            saveState(type);
        }

        /* ============================
           EXPORTAR IMAGEN
        ============================ */
        function getCanvasImage(type) {
            return canvases[type].toDataURL({
                format: 'png',
                quality: 1.0
            });
        }
    </script>
}
